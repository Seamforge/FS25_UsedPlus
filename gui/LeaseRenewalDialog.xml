<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    FS25_UsedPlus - Lease Renewal Dialog
    v2.15.0 - Full redesign following FieldServiceKit section pattern

    Unified dialog for lease expiration handling (both vehicles and land)
    Options: Return (get deposit back), Buyout (purchase asset), Renew (extend lease)

    Layout: Title + two-column info section + three clickable option cards + help text
    Button pattern: Three-layer custom buttons (Bitmap bg + invisible Button hit + Text labels)
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="dialogBg" id="dialogElement" size="720px 520px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title -->
            <Text profile="lrTitle" id="titleText" position="0px -18px" text="$l10n_usedplus_lr_title"/>
            <Text profile="lrSubtitle" id="assetNameText" position="0px -42px" text=""/>

            <!-- ========== SECTION: Lease Summary + Deposit Status (Two Columns) ========== -->
            <GuiElement profile="lrInfoSection" position="0px -65px">
                <Bitmap profile="lrInfoBg" position="0px 0px"/>

                <!-- Left Column: LEASE SUMMARY -->
                <Text profile="lrColumnHeader" position="-165px -8px" text="$l10n_usedplus_lr_sectionSummary"/>

                <Text profile="lrLabel" position="-215px -30px" text="$l10n_usedplus_lr_term"/>
                <Text profile="lrValue" id="termText" position="-65px -30px" text=""/>

                <Text profile="lrLabel" position="-215px -50px" text="$l10n_usedplus_lr_paymentsMade"/>
                <Text profile="lrValue" id="paymentsMadeText" position="-65px -50px" text=""/>

                <Text profile="lrLabel" position="-215px -70px" text="$l10n_usedplus_lr_totalPaid"/>
                <Text profile="lrMoneyGreen" id="totalPaidText" position="-65px -70px" text=""/>

                <Text profile="lrLabel" position="-215px -90px" text="$l10n_usedplus_lr_equityBuilt"/>
                <Text profile="lrMoneyGreen" id="equityText" position="-65px -90px" text=""/>

                <!-- Right Column: DEPOSIT STATUS -->
                <Text profile="lrColumnHeader" position="165px -8px" text="$l10n_usedplus_lr_sectionDeposit"/>

                <Text profile="lrLabel" position="115px -30px" text="$l10n_usedplus_lr_securityDeposit"/>
                <Text profile="lrValue" id="depositText" position="270px -30px" text=""/>

                <Text profile="lrLabel" position="115px -50px" text="$l10n_usedplus_lr_deductions"/>
                <Text profile="lrValue" id="deductionsText" position="270px -50px" text=""/>

                <Text profile="lrLabel" position="115px -70px" text="$l10n_usedplus_lr_refundAmount"/>
                <Text profile="lrMoneyGreen" id="refundText" position="270px -70px" text=""/>

                <!-- Vehicle condition (hidden for land) -->
                <Text profile="lrLabel" id="conditionLabel" position="115px -90px" text="$l10n_usedplus_lr_vehicleCondition"/>
                <Text profile="lrValue" id="conditionText" position="270px -90px" text=""/>
            </GuiElement>

            <!-- ========== SECTION: Options (Three clickable cards) ========== -->
            <GuiElement profile="lrOptionsSection" position="0px -190px">
                <Bitmap profile="lrOptionsBg" position="0px 0px"/>
                <Text profile="lrSectionHeader" position="0px -8px" text="$l10n_usedplus_lr_sectionOptions"/>

                <!-- Option 1: RETURN (triple-element button pattern) -->
                <GuiElement profile="lrOptionCard" position="-215px -32px">
                    <Bitmap profile="lrOptionCardBg" id="returnBg" position="0px 0px"/>
                    <Button profile="lrOptionBtn" id="returnButton" text="" onClick="onReturn"
                            onHighlight="onOptionHighlight" onHighlightRemove="onOptionUnhighlight" position="0px 0px"/>
                    <Bitmap profile="lrOptionIcon" id="returnIcon" position="0px -10px"/>
                    <Text profile="lrOptionTitle" position="0px -42px" text="$l10n_usedplus_lr_optionReturn"/>
                    <Text profile="lrOptionDesc" position="0px -60px" text="$l10n_usedplus_lr_optionReturnDesc"/>
                    <Text profile="lrOptionLabel" position="0px -78px" text="$l10n_usedplus_lr_youReceive"/>
                    <Text profile="lrOptionValueGreen" id="returnRefundText" position="0px -94px" text=""/>
                </GuiElement>

                <!-- Option 2: BUYOUT (triple-element button pattern) -->
                <GuiElement profile="lrOptionCard" position="0px -32px">
                    <Bitmap profile="lrOptionCardBg" id="buyoutBg" position="0px 0px"/>
                    <Button profile="lrOptionBtn" id="buyoutButton" text="" onClick="onBuyout"
                            onHighlight="onOptionHighlight" onHighlightRemove="onOptionUnhighlight" position="0px 0px"/>
                    <Bitmap profile="lrOptionIcon" id="buyoutIcon" position="0px -10px"/>
                    <Text profile="lrOptionTitle" position="0px -42px" text="$l10n_usedplus_lr_optionBuyout"/>
                    <Text profile="lrOptionDesc" position="0px -60px" text="$l10n_usedplus_lr_optionBuyoutDesc"/>
                    <Text profile="lrOptionLabel" position="0px -78px" text="$l10n_usedplus_lr_youPay"/>
                    <Text profile="lrOptionValueRed" id="buyoutPriceText" position="0px -94px" text=""/>
                </GuiElement>

                <!-- Option 3: RENEW (triple-element button pattern) -->
                <GuiElement profile="lrOptionCard" position="215px -32px">
                    <Bitmap profile="lrOptionCardBg" id="renewBg" position="0px 0px"/>
                    <Button profile="lrOptionBtn" id="renewButton" text="" onClick="onRenew"
                            onHighlight="onOptionHighlight" onHighlightRemove="onOptionUnhighlight" position="0px 0px"/>
                    <Bitmap profile="lrOptionIcon" id="renewIcon" position="0px -10px"/>
                    <Text profile="lrOptionTitle" position="0px -42px" text="$l10n_usedplus_lr_optionRenew"/>
                    <Text profile="lrOptionDesc" position="0px -60px" text="$l10n_usedplus_lr_optionRenewDesc"/>
                    <Text profile="lrOptionLabel" position="0px -78px" text="$l10n_usedplus_lr_equityCarries"/>
                    <Text profile="lrOptionValueGreen" id="renewEquityText" position="0px -94px" text=""/>
                </GuiElement>
            </GuiElement>

            <!-- Help Text -->
            <Text profile="lrHelpText" id="helpText" position="0px -360px" text="$l10n_usedplus_lr_helpText"/>

        </GuiElement>

        <!-- Button Box (Later only — actions via option cards above) -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" id="cancelButton" text="$l10n_usedplus_button_return" onClick="onReturn"/>
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>
        <!-- ========== TITLE ========== -->
        <Profile name="lrTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="660px 28px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="0.5 0.8 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="lrSubtitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="660px 20px"/>
            <textSize value="14px"/>
            <textColor value="0.7 0.7 0.7 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- ========== INFO SECTION (two-column container) ========== -->
        <Profile name="lrInfoSection" extends="emptyPanel" with="anchorTopCenter">
            <size value="660px 110px"/>
        </Profile>
        <Profile name="lrInfoBg" extends="baseReference" with="anchorTopCenter">
            <size value="660px 110px"/>
            <imageColor value="0.08 0.08 0.12 0.9"/>
        </Profile>

        <!-- Column headers (gold, centered over each column) -->
        <Profile name="lrColumnHeader" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="300px 18px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="1 0.8 0.2 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Labels (dim gray, left-aligned) -->
        <Profile name="lrLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="130px 18px"/>
            <textSize value="12px"/>
            <textColor value="0.7 0.7 0.7 1"/>
        </Profile>

        <!-- Values (white, left-aligned) -->
        <Profile name="lrValue" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="150px 18px"/>
            <textSize value="12px"/>
            <textColor value="1 1 1 1"/>
        </Profile>

        <!-- Money values -->
        <Profile name="lrMoneyGreen" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="150px 18px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="0.2 0.8 0.2 1"/>
        </Profile>

        <!-- ========== OPTIONS SECTION ========== -->
        <Profile name="lrSectionHeader" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="640px 20px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="1 0.8 0.2 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="lrOptionsSection" extends="emptyPanel" with="anchorTopCenter">
            <size value="660px 158px"/>
        </Profile>
        <Profile name="lrOptionsBg" extends="baseReference" with="anchorTopCenter">
            <size value="660px 158px"/>
            <imageColor value="0.06 0.06 0.10 0.9"/>
        </Profile>

        <!-- Option card (container) -->
        <Profile name="lrOptionCard" extends="emptyPanel" with="anchorTopCenter">
            <size value="208px 118px"/>
        </Profile>
        <!-- Option card background (visible, changes on hover) -->
        <Profile name="lrOptionCardBg" extends="baseReference" with="anchorTopCenter">
            <size value="208px 118px"/>
            <imageColor value="0.10 0.10 0.14 0.9"/>
        </Profile>
        <!-- Option card hit target (invisible, focusable) -->
        <Profile name="lrOptionBtn" extends="emptyPanel" with="anchorTopCenter">
            <size value="208px 118px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Option icon (set via Lua setImageFilename) -->
        <Profile name="lrOptionIcon" extends="baseReference" with="anchorTopCenter">
            <size value="28px 28px"/>
            <imageSliceId value="noSlice"/>
        </Profile>

        <!-- Option text styles -->
        <Profile name="lrOptionTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="196px 18px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="lrOptionDesc" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="196px 16px"/>
            <textSize value="10px"/>
            <textColor value="0.7 0.7 0.7 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="lrOptionLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="196px 14px"/>
            <textSize value="10px"/>
            <textColor value="0.6 0.6 0.6 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="lrOptionValueGreen" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="196px 18px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="0.2 0.8 0.2 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="lrOptionValueRed" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="196px 18px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="0.9 0.2 0.2 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- ========== HELP TEXT ========== -->
        <Profile name="lrHelpText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="660px 36px"/>
            <textSize value="11px"/>
            <textColor value="0.5 0.5 0.5 1"/>
            <textAlignment value="center"/>
        </Profile>
    </GUIProfiles>
</GUI>
