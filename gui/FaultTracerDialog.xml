        </Profile>

        <Profile name="ftComponentValue" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 18px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="0.3 1 0.3 1"/>
            <textAlignment value="center"/>
