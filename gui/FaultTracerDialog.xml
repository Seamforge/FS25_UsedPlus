            <textSize value="18px"/>
            <textBold value="true"/>
            <textColor value="0.9 0.75 0.3 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="ftComponentLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 18px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
