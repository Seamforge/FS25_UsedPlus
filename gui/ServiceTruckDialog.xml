            <textAlignment value="center"/>
        </Profile>

        <!-- ========== RESULTS ========== -->
        <Profile name="stResultSection" extends="emptyPanel" with="anchorTopCenter">
            <size value="700px 90px"/>
        </Profile>
        <Profile name="stResultBg" extends="baseReference" with="anchorTopCenter">
            <size value="700px 90px"/>
            <imageColor value="0.08 0.20 0.08 0.95"/>
        </Profile>
        <Profile name="stResultIcon" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="660px 20px"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textColor value="0.3 1.0 0.3 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="stResultTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="660px 20px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="stResultMessage" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="660px 18px"/>
            <textSize value="12px"/>
            <textColor value="0.8 0.8 0.8 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- ========== COMPONENT DETAIL (success) ========== -->
        <Profile name="stDetailSection" extends="emptyPanel" with="anchorTopCenter">
            <size value="700px 55px"/>
        </Profile>
        <Profile name="stDetailBg" extends="baseReference" with="anchorTopCenter">
            <size value="700px 55px"/>
            <imageColor value="0.08 0.08 0.10 0.9"/>
        </Profile>
        <Profile name="stDetailIcon" extends="baseReference" with="anchorTopCenter">
            <size value="32px 32px"/>
            <imageSliceId value="noSlice"/>
        </Profile>
        <Profile name="stDetailLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="250px 18px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="0.9 0.65 0.2 1"/>
        </Profile>
        <Profile name="stDetailValue" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="250px 16px"/>
            <textSize value="12px"/>
            <textColor value="0.8 0.8 0.8 1"/>
        </Profile>

        <!-- ========== REQUIREMENTS (success) ========== -->
        <Profile name="stReqSection" extends="emptyPanel" with="anchorTopCenter">
            <size value="700px 50px"/>
        </Profile>
        <Profile name="stReqBg" extends="baseReference" with="anchorTopCenter">
            <size value="700px 50px"/>
            <imageColor value="0.12 0.10 0.06 0.9"/>
