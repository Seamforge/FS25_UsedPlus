        <!-- ========== START RESTORATION BUTTON ========== -->
        <Profile name="stStartBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="600px 50px"/>
        </Profile>
        <Profile name="stStartBg" extends="baseReference" with="anchorTopCenter">
            <size value="600px 50px"/>
            <imageColor value="0.12 0.30 0.12 0.95"/>
        </Profile>
        <Profile name="stStartBtn" extends="emptyPanel" with="anchorTopCenter">
            <size value="600px 50px"/>
            <isFocusable value="true"/>
        </Profile>
        <Profile name="stStartText" extends="fs25_textDefault" with="anchorTopCenter">
