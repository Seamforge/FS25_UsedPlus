<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    FS25_UsedPlus - Sale Offer Dialog XML

    REDESIGNED v1.9.6: Player-focused framing
    - Removed "vanilla" terminology - players don't think that way
    - Added deal quality rating (★★★★☆)
    - Shows expected range with visual positioning
    - "Keep Waiting" instead of "Decline" - implies hope

    v1.9.7: Simplified "Your Options" section
    - Removed "Sell Instantly" (no instant sell in UsedPlus)
    - Removed confusing "+X%" bonus display
    - Fixed positioning (anchorTopCenter for proper centering)

    Pattern from MessageDialog (working reference)
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />

    <GuiElement profile="dialogBg" id="dialogElement" size="720px 656px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title: "BUYER FOUND!" is more exciting than "Sale Offer Received" -->
            <Text profile="fs25_dialogTitle" id="dialogTitleElement" position="0px -30px" text="$l10n_usedplus_so_title_v2"/>

            <!-- ================================================================ -->
            <!-- SECTION 1: Vehicle Info (compact header) -->
            <!-- ================================================================ -->
            <GuiElement profile="soSectionBg" position="0px -60px" size="680px 95px">
                <!-- Vehicle image on left, info on right -->
                <!-- Standard position: -185px 42px (X=left of center, Y=moves UP) -->
                <Bitmap profile="soVehicleImage" id="vehicleImage" position="-185px 75px"/>
                <GuiElement position="60px -10px">
                    <Text profile="soVehicleName" id="vehicleNameText" position="0px 0px"/>
                    <Text profile="soAgentInfo" id="agentTierText" position="0px -28px"/>
                </GuiElement>
            </GuiElement>

            <!-- ================================================================ -->
            <!-- SECTION 2: THE OFFER (prominent center display) -->
            <!-- ================================================================ -->
            <GuiElement profile="soSectionBg" position="0px -165px" size="680px 100px">
                <!-- Large offer amount -->
                <Text profile="soOfferAmount" id="offerAmountText" position="0px -15px"/>
                <!-- v2.13.2: Deal rating stars (image icons replace Unicode ★☆ that don't render in FS25 font) -->
                <Bitmap profile="soStarIcon" id="star1" position="-110px -55px"/>
                <Bitmap profile="soStarIcon" id="star2" position="-84px -55px"/>
                <Bitmap profile="soStarIcon" id="star3" position="-58px -55px"/>
                <Bitmap profile="soStarIcon" id="star4" position="-32px -55px"/>
                <Bitmap profile="soStarIcon" id="star5" position="-6px -55px"/>
                <!-- Deal rating text (v2.13.2: text only, stars are now images above) -->
                <Text profile="soDealRating" id="dealRatingText" position="60px -55px"/>
            </GuiElement>

            <!-- ================================================================ -->
            <!-- SECTION 3: Expected Range (visual indicator) -->
            <!-- ================================================================ -->
            <GuiElement profile="soSectionBg" position="0px -275px" size="680px 123px">
                <Text profile="soSectionLabel" position="0px -3px" text="$l10n_usedplus_so_expectedRange"/>

                <!-- 21 arrow markers at fixed positions (0% to 100% in 5% steps) -->
                <!-- Pattern: baseReference + noSlice, image loaded via Lua setImageFilename -->
                <!-- Only the closest to offer position is visible (setVisible) -->
                <!-- Bar is 450px wide: 0%=-225px, each 5%=+22.5px, 100%=+225px -->
                <Bitmap profile="soArrowMarker" id="arrow0"   position="-225px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow5"   position="-203px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow10"  position="-180px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow15"  position="-158px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow20"  position="-135px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow25"  position="-113px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow30"  position="-90px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow35"  position="-68px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow40"  position="-45px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow45"  position="-23px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow50"  position="0px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow55"  position="23px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow60"  position="45px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow65"  position="68px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow70"  position="90px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow75"  position="113px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow80"  position="135px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow85"  position="158px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow90"  position="180px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow95"  position="203px -18px"/>
                <Bitmap profile="soArrowMarker" id="arrow100" position="225px -18px"/>

                <!-- Range bar background (no id — renders fine) -->
                <Bitmap profile="soRangeBarBg" position="0px -38px"/>

                <!-- v2.16.0: Previous offer history markers (gray ▲ below bar, shown for declined offers) -->
                <!-- 11 positions at 10% intervals: 0%=-225, 10%=-180, 20%=-135, etc. -->
                <Bitmap profile="soHistoryMarker" id="histMarker0"   position="-225px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker10"  position="-180px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker20"  position="-135px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker30"  position="-90px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker40"  position="-45px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker50"  position="0px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker60"  position="45px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker70"  position="90px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker80"  position="135px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker90"  position="180px -52px"/>
                <Bitmap profile="soHistoryMarker" id="histMarker100" position="225px -52px"/>

                <!-- Offer position as clean text (shifted down 18px for history row) -->
                <Text profile="soRangeOfferHighlight" id="rangeOfferText" position="0px -74px"/>

                <!-- Min / Max price labels (shifted down 18px) -->
                <Text profile="soRangeValue" id="rangeMinText" position="-200px -74px"/>
                <Text profile="soRangeValue" id="rangeMaxText" position="200px -74px"/>

                <!-- Labels below values (shifted down 18px) -->
                <Text profile="soRangeLabel" position="-200px -90px" text="$l10n_usedplus_so_rangeMin"/>
                <Text profile="soRangeLabelHighlight" position="0px -90px" text="$l10n_usedplus_so_rangeOffer"/>
                <Text profile="soRangeLabel" position="200px -90px" text="$l10n_usedplus_so_rangeMax"/>
            </GuiElement>

            <!-- ================================================================ -->
            <!-- SECTION 4: Your Options (simplified layout like LoanApprovedDialog) -->
            <!-- ================================================================ -->
            <GuiElement profile="soOptionsSection" position="0px -398px">
                <Bitmap profile="soOptionsBg" position="0px 0px"/>
                <Text profile="soSectionLabel" position="0px -8px" text="$l10n_usedplus_so_yourOptions"/>

                <!-- Row 1: Accept Offer - label left, value right -->
                <Text profile="soOptionLabel" position="-100px -35px" text="$l10n_usedplus_so_thisOffer"/>
                <Text profile="soOptionValue" id="thisOfferText" position="100px -35px"/>

                <!-- Row 2: Keep Waiting - label left, note right -->
                <!-- v2.13.2: Shifted note from 100px to 130px to avoid overlap with wider profile -->
                <Text profile="soOptionLabel" position="-100px -58px" text="$l10n_usedplus_so_keepWaiting"/>
                <Text profile="soOptionNote" position="130px -58px" text="$l10n_usedplus_so_keepWaitingNote"/>

                <!-- v2.16.0: Previous offers summary (only shown when history exists) -->
                <Text profile="soOptionLabel" id="prevOffersLabel" position="-100px -81px" text="$l10n_usedplus_so_previousOffers"/>
                <Text profile="soOptionNote" id="prevOffersText" position="130px -81px"/>
            </GuiElement>

            <!-- ================================================================ -->
            <!-- SECTION 5: Expiration Warning (v2.9.5: timer icon) -->
            <!-- ================================================================ -->
            <GuiElement position="0px -521px">
                <Bitmap profile="soTimerIcon" id="timerIcon" position="-125px -5px"/>
                <Text profile="soExpirationLabel" position="20px -5px" text="$l10n_usedplus_so_expiresIn"/>
                <!-- v2.13.2: Shifted right 10px per user feedback -->
                <Text profile="soExpirationValue" id="expirationText" position="120px -5px"/>
            </GuiElement>

        </GuiElement>

        <!-- Buttons -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonOK" id="acceptButton" text="$l10n_usedplus_so_acceptOffer" onClick="onClickAccept"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="soKeepWaitingBtn" id="declineButton" text="$l10n_usedplus_so_keepWaitingBtn" onClick="onClickDecline"/>
        </BoxLayout>

    </GuiElement>

    <!-- ================================================================ -->
    <!-- CUSTOM PROFILES -->
    <!-- ================================================================ -->
    <GUIProfiles>
        <!-- Section background (dark panel) -->
        <Profile name="soSectionBg" extends="emptyPanel" with="anchorTopCenter">
            <bgColor value="0.05 0.05 0.08 0.9"/>
        </Profile>

        <!-- v2.13.2: Deal rating star icon (filled or empty, set via Lua setImageFilename) -->
        <Profile name="soStarIcon" extends="baseReference" with="anchorTopCenter">
            <size value="24px 24px"/>
            <imageSliceId value="noSlice"/>
        </Profile>

        <!-- v2.9.5: Timer icon -->
        <Profile name="soTimerIcon" extends="baseReference" with="anchorTopCenter">
            <size value="24px 24px"/>
            <imageSliceId value="noSlice"/>
        </Profile>

        <!-- Following RVB pattern: baseReference + square size + noSlice -->
        <Profile name="soVehicleImage" extends="baseReference" with="anchorTopCenter">
            <size value="180px 180px"/>
            <imageSliceId value="noSlice"/>
        </Profile>

        <!-- Vehicle name (v2.13.2: explicit width to prevent truncation of long names) -->
        <Profile name="soVehicleName" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="280px 24px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
        </Profile>

        <!-- Agent/tier info (subtle, v2.13.2: explicit width) -->
        <Profile name="soAgentInfo" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="280px 18px"/>
            <textSize value="14px"/>
            <textColor value="0.6 0.6 0.6 1"/>
        </Profile>

        <!-- Section labels -->
        <Profile name="soSectionLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="0.7 0.7 0.7 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- THE OFFER amount (big, green, prominent) -->
        <Profile name="soOfferAmount" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="36px"/>
            <textBold value="true"/>
            <textColor value="0.3 1 0.3 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Deal rating (stars + text) -->
        <Profile name="soDealRating" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="18px"/>
            <textBold value="true"/>
            <textColor value="1 0.85 0.2 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Range bar background -->
        <Profile name="soRangeBarBg" extends="baseReference" with="anchorTopCenter">
            <size value="450px 12px"/>
            <imageColor value="0.15 0.15 0.2 1"/>
        </Profile>

        <!-- Range bar fill (green gradient) -->
        <Profile name="soRangeBarFill" extends="baseReference" with="anchorTopCenter">
            <size value="450px 12px"/>
            <imageColor value="0.2 0.6 0.3 1"/>
        </Profile>

        <!-- Arrow marker icon: same pattern as dialog section icons (CLAUDE.md) -->
        <!-- baseReference + noSlice + NO imageColor = image loaded via setImageFilename in Lua -->
        <Profile name="soArrowMarker" extends="baseReference" with="anchorTopCenter">
            <size value="20px 20px"/>
            <imageSliceId value="noSlice"/>
        </Profile>

        <!-- v2.16.0: History offer marker - gray upward triangle below range bar -->
        <Profile name="soHistoryMarker" extends="baseReference" with="anchorTopCenter">
            <size value="16px 16px"/>
            <imageSliceId value="noSlice"/>
        </Profile>

        <!-- Offer position highlight text -->
        <Profile name="soRangeOfferHighlight" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="0.3 1 0.3 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Range values (min/max) -->
        <Profile name="soRangeValue" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="14px"/>
            <textColor value="0.7 0.7 0.7 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Range value highlighted (offer) -->
        <Profile name="soRangeValueHighlight" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="0.3 1 0.3 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Range labels -->
        <Profile name="soRangeLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="10px"/>
            <textColor value="0.5 0.5 0.5 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Range label highlighted -->
        <Profile name="soRangeLabelHighlight" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="10px"/>
            <textBold value="true"/>
            <textColor value="0.3 0.9 0.3 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Options section container (v2.16.0: expanded for previous offers row) -->
        <Profile name="soOptionsSection" extends="emptyPanel" with="anchorTopCenter">
            <size value="680px 108px"/>
        </Profile>

        <!-- Options section background (v2.16.0: expanded for previous offers row) -->
        <Profile name="soOptionsBg" extends="baseReference" with="anchorTopCenter">
            <size value="680px 108px"/>
            <imageColor value="0.05 0.05 0.08 0.9"/>
        </Profile>

        <!-- Option label (left side, right-aligned text) -->
        <Profile name="soOptionLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="180px 20px"/>
            <textSize value="14px"/>
            <textColor value="0.8 0.8 0.8 1"/>
            <textAlignment value="right"/>
        </Profile>

        <!-- Option value (right side, left-aligned, green) -->
        <Profile name="soOptionValue" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="180px 20px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="0.3 1 0.3 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Option note (right side, left-aligned, subtle) -->
        <!-- v2.13.2: Widened from 180px to 240px to prevent truncation of long notes -->
        <Profile name="soOptionNote" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="240px 20px"/>
            <textSize value="12px"/>
            <textColor value="0.6 0.6 0.6 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Expiration icon -->
        <Profile name="soExpirationIcon" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="18px"/>
            <textColor value="1 0.6 0.2 1"/>
        </Profile>

        <!-- Expiration label -->
        <Profile name="soExpirationLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="14px"/>
            <textColor value="1 0.7 0.3 1"/>
        </Profile>

        <!-- Expiration value -->
        <Profile name="soExpirationValue" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="1 0.5 0.2 1"/>
        </Profile>

        <!-- v2.8.0: Keep Waiting button - wider to prevent text truncation -->
        <Profile name="soKeepWaitingBtn" extends="buttonBack">
            <size value="200px 50px"/>
            <textTruncation value="false"/>
        </Profile>
    </GUIProfiles>
</GUI>
